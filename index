<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>人間観察記録システム</title>
<style>
:root{
  --bg:#f7f6f3;
  --card:#ffffff;
  --line:#dedad2;
  --text:#2f2f2f;
  --sub:#777;
}
*{
  box-sizing:border-box;
}
body{
  margin:0;
  padding:24px;
  font-family:
  "Hiragino Sans",
  "Yu Gothic",
  sans-serif;
  background:var(--bg);
  color:var(--text);
}
.container{
  max-width:720px;
  margin:auto;
}
header{
  margin-bottom:24px;
}
h1{
  margin:0;
  font-size:28px;
}
.subtitle{
  color:var(--sub);
  font-size:14px;
}
.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:14px;
  padding:16px;
  margin-bottom:14px;
}
.label{
  font-size:12px;
  color:var(--sub);
  margin-bottom:6px;
}
.value{
  font-size:18px;
}
#mugiMessage{
  min-height:72px;
  line-height:1.8;
}
footer{
  margin-top:40px;
  color:var(--sub);
  font-size:12px;
  text-align:center;
}
button{
  border:none;
  border-radius:999px;
  padding:10px 14px;
  cursor:pointer;
}
#mugiButton{
  width:100%;
}
</style>
</head>
<body>
<div class="container">
<header>
<h1>人間観察記録システム</h1>
<div class="subtitle">
管理者：むぎ 🐈‍⬛
</div>
</header>
<div class="card">
<div class="label">観察対象</div>
<div class="value" id="nickname">
判定中...
</div>
</div>
<div class="card">
<div class="label">本日の態度</div>
<div class="value" id="attitude">
判定中...
</div>
</div>
<div class="card">
<div class="label">観察開始から</div>
<div class="value" id="siteAge">
0日
</div>
</div>
<div class="card">
<div class="label">訪問回数</div>
<div class="value" id="visitCount">
0
</div>
</div>
<div class="card">
<div class="label">むぎの声</div>
<div id="mugiMessage">
……
</div>
</div>
<div class="card">
<button id="mugiButton">
むぎに話しかける
</button>
</div>
<footer>
Human Observation System v2.0
</footer>
<script>
/* ===========================
   初期データ
=========================== */
const moods = [
 "salt",
 "observer",
 "tsukkomi"
];
const nicknames = [
 "考えすぎる人間",
 "せわしない人間",
 "観察好きな人間",
 "静かな人間",
 "また来た人間",
 "気になる人間"
];
const saltMessages = [
 "また来たのか。",
 "特に用件はない。",
 "見ている。"
];
const observerMessages = [
 "観察を継続する。",
 "本日も変化なし。",
 "人間は興味深い。"
];
const tsukkomiMessages = [
 "それ意味あるのか？",
 "急に押したな。",
 "落ち着け。"
];
</script>
</body>
</html>
